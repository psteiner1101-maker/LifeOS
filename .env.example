# Copy this file to .env.local and fill in real values from your own Supabase
# project settings (Project Settings > API). Never commit .env.local or any
# file containing real keys/secrets.
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only — bypasses Row Level Security. Never expose to the browser
# (never prefix with NEXT_PUBLIC_). Used only by lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# This app's own base URL, used to construct auth email redirect links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
